STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here

# Optional production worker split:
# Set these on Vercel so the website forwards long-running scraper work
# to a worker service instead of trying to scrape inside a Vercel function.
SCRAPER_WORKER_URL=https://your-worker-service.example.com
SCRAPER_WORKER_TOKEN=replace_with_same_secret_as_worker

# Set this only on the worker service. If present, scraper start/stop calls
# must include X-Scraper-Token with this value.
WORKER_TOKEN=replace_with_same_secret_as_vercel

# Optional CA scraper tuning. Higher = more volume but slower.
CA_NOTICE_MAX_DETAILS=150
CA_NOTICE_LOOKBACK_DAYS=60
