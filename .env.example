STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Required for login sessions. Use a long random value in production.
SECRET_KEY=replace_with_a_long_random_secret

# Protects /admin/skiptrace. Use a long random value.
SKIPTRACE_ADMIN_TOKEN=replace_with_a_long_random_admin_token

# Comma-separated login emails allowed to see /admin and run local tools.
ADMIN_EMAIL=admin@example.com

# Required for accounts + purchased lead unlocks on Vercel.
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=replace_with_appwrite_project_id
APPWRITE_API_KEY=replace_with_appwrite_api_key
APPWRITE_DATABASE_ID=tax_delinquencies
APPWRITE_USERS_COLLECTION_ID=users
APPWRITE_ORDERS_COLLECTION_ID=orders

# Optional legacy fallback for accounts + purchased lead unlocks.
# Vercel Postgres/Neon may provide POSTGRES_URL instead.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Local SQLite data store used by the scraper/admin app.
SQLITE_DB=foreclosure_local.sqlite3

# Optional CA scraper tuning. Higher = more volume but slower.
CA_NOTICE_MAX_DETAILS=150
CA_NOTICE_LOOKBACK_DAYS=60
